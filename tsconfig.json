{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "experimentalDecorators": true, // for inversify
        "emitDecoratorMetadata": true // for inversify
    },
    "include": [
        "src/**/*"
    ]
}